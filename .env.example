# =============================================================================
# UMTELKOMD — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
# En producción: el puerto por defecto de PostgreSQL es 5432.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://umtelkomd:CONTRASEÑA_SEGURA@localhost:5432/umtelkomd"

# -----------------------------------------------------------------------------
# NEXTAUTH
# NEXTAUTH_SECRET: genera con `openssl rand -base64 32`
# NEXTAUTH_URL: URL pública completa de la aplicación (con https en producción)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="https://umtelkomd.net"

# -----------------------------------------------------------------------------
# CLOUDINARY — Almacenamiento de imágenes (avatares, fotos de inventario)
# Crea una cuenta en https://cloudinary.com y obtén las credenciales
# desde Dashboard > API Keys.
# Si estas variables no están presentes, las imágenes se guardan en /public/uploads/
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# -----------------------------------------------------------------------------
# EMAIL — Resend (https://resend.com)
# RESEND_API_KEY: obtén desde resend.com > API Keys
# EMAIL_FROM:
#   - Desarrollo: "onboarding@resend.dev" (solo llega al dueño de la cuenta Resend)
#   - Producción: "noreply@umtelkomd.de" tras verificar el dominio en resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@umtelkomd.de"

# -----------------------------------------------------------------------------
# APP — URLs públicas accesibles desde el cliente (browser)
# NEXT_PUBLIC_APP_URL: URL base (usada en links de emails, QR codes, etc.)
# NEXT_PUBLIC_APP_NAME: Nombre visible en la interfaz y PDFs exportados
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://umtelkomd.net"
NEXT_PUBLIC_APP_NAME="Umtelkomd"
